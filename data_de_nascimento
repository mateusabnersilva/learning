ano = 2026

maiores = 0
menores = 0

for i in range(1, 8):

    data = int(input('Digite sua data de nascimento: '))
    maioridade = ano - data

    if maioridade >= 18:
        maiores += 1
    else:
        menores += 1


print(f'{maiores} pessoas atingiram a maioridade')
print(f'{menores} não atingiram a maioridade')