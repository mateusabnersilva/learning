print('{:=^40}'.format(' LOJAS ATACADO '))

preco = float(input('Preço das compras: R$'))

print(''' FORMAS DE PAGAMENTO
[1] à vista dinheiro/cheque
[2] à vista no cartão
[3] 2x no cartão
[4] 3x ou mais no cartão''')

opcao = int(input('Escolha a opção acima: '))

if opcao == 1:
    total = preco - (preco * 10 / 100)
elif opcao == 2: 
    total = preco - (preco * 5 / 100)
elif opcao == 3:
    total = preco 
    parcela = total / 2
    print('Sua compra será parcelada em 2x de R${:.2f} SEM JUROS'.format(parcela))
elif opcao == 4:
    total = preco + (preco * 20 / 100)
    num_de_parcelas = int(input('Quanats parcelas? '))
    parcela = total / num_de_parcelas
    print('Sua compra será parcelada em {}x de R${:.2f} COM JUROS'.format(num_de_parcelas, parcela))
else: 
    total = preco
    print('OPÇÃO INVÁLIDA DE PAGAMENTO. TENTE NOVAMENTE!')
print('Sua compra de R${:.2f} vai custar R${:.2f} no final'.format(preco, total))
  