""" Range: Usada para gerar uma sequência de números inteiros.

    range(start, stop, step), ele somente aceita números inteiros"""

for num in range(1, 5): # Começa em 1 e termina em 4, pois o 'stop' não é inclusivo.
    print(num)

for num in range (2, 11, 2): # Começa do número 2 até o 10 em sequência par (de 2 em 2)
    print(num)

for num in range(40, 0, -10): # Em lógica, o número deve diminuir em 10 dem 10. 
    print(num)

numbers = list(range(2, 11, 2)) # Lista de inteiros
print(numbers)

languages = ['Spanish', 'English', 'Russian', 'Chinese']

index = 0 # index = índice

for language in languages:
    print(f'Index {index} and language {language}')
    index += 1

languages = ['Spanish', 'English', 'Russian', 'Chinese']

for index, language in enumerate(languages, 1):
    print(f'Index {index} and language {language}')

