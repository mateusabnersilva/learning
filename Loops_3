even_numbers = [num for num in range(21) if num % 2 == 0]
print(even_numbers) 

numbers = [1, 2, 3, 4, 5]
result = [(num, 'Even') if num % 2 == 0 else (num, 'Odd') for num in numbers]
print(result)



words = ['tree', 'sky', 'mountain', 'river', 'cloud', 'sun']

def is_long_word(word):
    return len(word) > 4

long_word = list(filter(is_long_word, words)) # Filter(): selecioa elementos de um itineravel que atendem uma condição específica.
print(long_word)



cel = [0, 10, 20, 30, 40]

def to_fahrenheit(temp):
    return (temp * 9/5) + 32

fahrenheit = list(map(to_fahrenheit, cel)) 
print(fahrenheit)

